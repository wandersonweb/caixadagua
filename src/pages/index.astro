---
import BaseLayout from "@layouts/BaseLayout.astro";
import { servicesData } from "@data/services";
import { testimonialsData } from "@data/testimonials";
import { companyInfo } from "@data/company";
import { getLocalBusinessSchema } from "@utils/schema";
import ServiceCard from "@components/ui/ServiceCard.astro";
import BlogCard from "@components/ui/BlogCard.astro";
import SectionTitle from "@components/ui/SectionTitle.astro";

const localBusinessSchema = getLocalBusinessSchema();
---

<BaseLayout isHome={true} schema={localBusinessSchema}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-brand-dark to-[#100e16] text-white py-20 sm:py-32 overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#2351ff_1px,transparent_1px)] [background-size:16px_16px]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        
        <div class="lg:col-span-7 space-y-6 text-center lg:text-left">
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-primary/10 text-primary border border-primary/20 uppercase tracking-widest">
            Profissionais NR33 & NR35
          </span>
          <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight text-white leading-tight">
            Especialistas em Reforma e Manutenção de <span class="text-gradient">Caixa D'Água</span>
          </h1>
          <p class="text-lg text-brand-gray leading-relaxed max-w-2xl mx-auto lg:mx-0">
            Problemas com vazamentos na sua caixa d’água de fibra? Não espere mais! Clique agora e fale conosco pelo WhatsApp para uma reforma rápida e segura. Garanta água limpa e reservatório em perfeito estado!
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 pt-2">
            <a
              href={companyInfo.whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 h-14 text-sm font-bold text-white bg-whatsapp hover:bg-whatsapp-hover rounded-xl shadow-xl shadow-whatsapp/15 transform hover:-translate-y-0.5 transition-all"
            >
              Falar no WhatsApp
            </a>
            <a
              href="/servicos/"
              class="w-full sm:w-auto inline-flex items-center justify-center px-8 h-14 text-sm font-bold text-white bg-white/10 hover:bg-white/20 border border-white/10 rounded-xl transition-all"
            >
              Conhecer Nossos Serviços
            </a>
          </div>
        </div>

        <!-- Trust Form / Promo Card -->
        <div class="lg:col-span-5">
          <div class="bg-white/5 border border-white/10 rounded-3xl p-6 sm:p-8 backdrop-blur-md shadow-2xl relative overflow-hidden">
            <div class="space-y-6 relative z-10">
              <div class="text-center">
                <span class="text-xs text-primary font-bold tracking-widest uppercase">Atendimento Rápido</span>
                <h2 class="text-2xl font-bold text-white mt-1">Solicite um Orçamento</h2>
                <p class="text-xs text-brand-gray mt-2 leading-relaxed">
                  Realizamos reforma de caixas de fibra de vidro, concreto e cisternas com garantia total na Grande Belo Horizonte.
                </p>
              </div>
              <div class="space-y-4">
                <div class="flex items-center gap-3 p-4 rounded-xl bg-white/5 border border-white/5">
                  <div class="w-8 h-8 rounded-lg bg-whatsapp/10 text-whatsapp flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-sm font-bold text-white leading-tight">Segurança Certificada</h3>
                    <p class="text-[11px] text-brand-gray">Profissionais treinados em NR33 e NR35.</p>
                  </div>
                </div>
                <div class="flex items-center gap-3 p-4 rounded-xl bg-white/5 border border-white/5">
                  <div class="w-8 h-8 rounded-lg bg-primary/10 text-primary flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-sm font-bold text-white leading-tight">Atendimento Imediato</h3>
                    <p class="text-[11px] text-brand-gray">Orçamento gratuito sem compromisso via WhatsApp.</p>
                  </div>
                </div>
              </div>
              <a
                href={companyInfo.whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2 w-full py-4 text-sm font-bold text-white bg-whatsapp hover:bg-whatsapp-hover rounded-xl shadow-lg transition-all transform hover:-translate-y-0.5"
              >
                Chame no WhatsApp Agora
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Statistics / Trust Badges Grid -->
  <section class="py-12 bg-brand-bg-light border-y border-brand-border/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center sm:text-left">
        <div class="flex flex-col sm:flex-row items-center gap-4">
          <div class="w-12 h-12 rounded-2xl bg-white border border-brand-border flex items-center justify-center text-primary shadow-sm shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.746 3.746 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
            </svg>
          </div>
          <div>
            <h3 class="text-base font-bold text-brand-dark">Equipe Certificada</h3>
            <p class="text-xs text-brand-gray leading-relaxed">Técnicos com habilitação NR33 para espaços confinados e NR35 para alturas.</p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center gap-4">
          <div class="w-12 h-12 rounded-2xl bg-white border border-brand-border flex items-center justify-center text-primary shadow-sm shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A1.75 1.75 0 1 0 19.75 18.5l-5.83-5.83M11.42 15.17a3 3 0 1 1-4.24-4.24 3 3 0 0 1 4.24 4.24Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M18.41 8.586a3.75 3.75 0 1 1-5.3 5.3c-.347-.346-.71-.628-1.077-.852l-.462-.283a2.625 2.625 0 0 0-3.712 0l-.18.18a2.625 2.625 0 0 0 0 3.712l.18.18a2.625 2.625 0 0 0 3.712 0l.18-.18" />
            </svg>
          </div>
          <div>
            <h3 class="text-base font-bold text-brand-dark">Materiais Certificados</h3>
            <p class="text-xs text-brand-gray leading-relaxed">Utilizamos resinas e impermeabilizantes atóxicos adequados para água potável.</p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center gap-4">
          <div class="w-12 h-12 rounded-2xl bg-white border border-brand-border flex items-center justify-center text-primary shadow-sm shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.125 2.25h3.75a.75.75 0 0 1 .75.75v1.125c0 .414.336.75.75.75h4.125c.414 0 .75.336.75.75v14.25a.75.75 0 0 1-.75.75h-15.75a.75.75 0 0 1-.75-.75V5.625c0-.414.336-.75.75-.75H7.5A.75.75 0 0 1 8.25 4.125V3a.75.75 0 0 1 .75-.75Zm1.5 6.75a.75.75 0 0 0 0 1.5h1.5a.75.75 0 0 0 0-1.5h-1.5Zm0 3.75a.75.75 0 0 0 0 1.5h1.5a.75.75 0 0 0 0-1.5h-1.5Zm0 3.75a.75.75 0 0 0 0 1.5h1.5a.75.75 0 0 0 0-1.5h-1.5ZM8.25 9.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm0 3.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm0 3.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z" />
            </svg>
          </div>
          <div>
            <h3 class="text-base font-bold text-brand-dark">Atendimento Corporativo</h3>
            <p class="text-xs text-brand-gray leading-relaxed">Estruturados para atender indústrias, comércio, condomínios e residências.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Showcase Grid -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle
        subtitle="O que fazemos de melhor"
        title="Nossos Serviços Especializados"
      />
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-12 sm:mt-16">
        {servicesData.map((service) => (
          <ServiceCard service={service} />
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits Banner / Company Overview snippet -->
  <section class="py-20 sm:py-24 bg-brand-bg-light border-y border-brand-border/60 overflow-hidden relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-6">
          <SectionTitle
            subtitle="Qualidade e Confiança"
            title="Referência em Reforma e Manutenção de Caixas"
            align="left"
          />
          <p class="text-base text-brand-dark/85 leading-relaxed">
            Avaliamos constantemente nosso desempenho para garantir a excelência em nossos serviços de reforma e manutenção de caixas d’água. Oferecemos soluções completas e seguras para vazamentos, rachaduras e problemas de vedação de reservatórios.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-2">
            <div class="flex items-center gap-2">
              <span class="w-5 h-5 rounded-full bg-primary/10 text-primary flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
              </span>
              <span class="text-sm font-semibold text-brand-dark">Equipe Altamente Qualificada</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-5 h-5 rounded-full bg-primary/10 text-primary flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
              </span>
              <span class="text-sm font-semibold text-brand-dark">Soluções Personalizadas</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-5 h-5 rounded-full bg-primary/10 text-primary flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
              </span>
              <span class="text-sm font-semibold text-brand-dark">Reparos em Diversos Materiais</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-5 h-5 rounded-full bg-primary/10 text-primary flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
              </span>
              <span class="text-sm font-semibold text-brand-dark">Reservatórios em Perfeito Estado</span>
            </div>
          </div>
          <div class="pt-4">
            <a
              href="/sobre-nos/"
              class="inline-flex items-center justify-center px-6 h-12 text-sm font-bold text-white bg-primary hover:bg-primary-hover rounded-xl shadow-md transition-all"
            >
              Conheça Nossa História
            </a>
          </div>
        </div>

        <div class="relative">
          <!-- Visual Decoration representing a clean pool/water -->
          <div class="absolute inset-0 bg-gradient-to-tr from-primary/10 to-primary/20 rounded-3xl blur-3xl transform rotate-3 scale-95 opacity-80"></div>
          <div class="relative bg-white border border-brand-border/60 rounded-3xl p-6 sm:p-10 shadow-lg space-y-6">
            <span class="text-xs font-bold text-primary tracking-widest uppercase">Excelência e Confiabilidade</span>
            <blockquote class="text-lg font-medium text-brand-dark italic leading-relaxed">
              "Todos os Direitos Reservados - Reforma e Manutenção de caixas d'água. Oferecemos segurança estrutural e higiene garantida para seu sistema de água potável em condomínios e edifícios em BH."
            </blockquote>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold text-sm">
                CS
              </div>
              <div>
                <h4 class="text-sm font-bold text-brand-dark">Caixas São Bento</h4>
                <p class="text-xs text-brand-gray">Especialistas em Reservatórios</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionTitle
        subtitle="Opinião de quem contrata"
        title="O Que Dizem Nossos Clientes"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12 sm:mt-16">
        {testimonialsData.map((t) => (
          <div class="bg-brand-bg-light border border-brand-border/40 rounded-3xl p-6 sm:p-8 flex flex-col justify-between hover:shadow-md transition-all duration-300">
            <div class="space-y-4">
              <!-- Rating Stars -->
              <div class="flex items-center gap-1 text-amber-500">
                {Array.from({ length: t.rating }).map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                    <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
                  </svg>
                ))}
              </div>
              <p class="text-sm text-brand-dark/80 leading-relaxed font-medium">
                "{t.text}"
              </p>
            </div>
            <div class="flex items-center gap-3 pt-6 mt-6 border-t border-brand-border/30">
              <div class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold text-xs">
                {t.name.split(" ").map(n => n[0]).join("")}
              </div>
              <div>
                <h4 class="text-sm font-bold text-brand-dark leading-none">{t.name}</h4>
                <span class="text-xs text-brand-gray font-medium mt-1 inline-block">{t.role} - {t.location}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest SEO Guides -->
  <section class="py-20 sm:py-28 bg-brand-bg-light border-y border-brand-border/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12 sm:mb-16">
        <SectionTitle
          subtitle="Dicas de quem entende"
          title="Guias e Conteúdos Recentes"
          align="left"
          className="m-0"
        />
        <a
          href="/servicos/"
          class="inline-flex items-center gap-1.5 text-sm font-bold text-primary hover:text-primary-hover transition-colors shrink-0"
        >
          Ver Serviços
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="m13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <BlogCard
          title="Como Consertar Caixa d'Água de Fibra Rachada"
          description="Entenda quando vale a pena reparar uma caixa de fibra rachada, como funciona o reforço com resina e quais sinais indicam vazamento."
          slug="consertar-caixa-d-agua-de-fibra"
          category="Reparos"
        />
        <BlogCard
          title="Frequência Ideal para Limpeza de Reservatórios"
          description="Entenda por que a ANVISA recomenda a higienização completa das caixas d'água a cada 6 meses e os riscos à saúde de negligenciar essa manutenção."
          slug="limpeza-de-caixa-dagua"
          category="Limpeza"
        />
        <BlogCard
          title="Infiltrações em Reservatórios de Concreto: O que Fazer?"
          description="Guia prático para identificar trincas estruturais em cisternas de condomínios e como a impermeabilização polimérica resolve vazamentos recorrentes."
          slug="reforma-de-caixa-dagua-de-concreto"
          category="Impermeabilização"
        />
        <BlogCard
          title="Quando Fazer Manutenção Preventiva na Caixa d'Água"
          description="Boias, flanges, tampas e registros precisam de inspeção periódica para evitar transbordamentos, desperdício e contaminação."
          slug="manutencao-de-caixa-d-agua"
          category="Manutenção"
        />
        <BlogCard
          title="Reforma de Caixa d'Água: Sinais de Alerta"
          description="Veja os sintomas mais comuns de desgaste no reservatório e por que rachaduras e manchas de umidade não devem ser ignoradas."
          slug="reforma-de-caixa-dagua"
          category="Reforma"
        />
        <BlogCard
          title="Impermeabilização de Caixa d'Água em Condomínios"
          description="Saiba como a impermeabilização correta protege a estrutura, evita infiltrações e ajuda síndicos a reduzirem custos emergenciais."
          slug="impermeabilizacao-de-caixa-dagua"
          category="Condomínios"
        />
      </div>
    </div>
  </section>

  <!-- Call to Action Banner -->
  <section class="py-20 sm:py-24 bg-white text-center">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6">
      <span class="text-xs font-bold text-primary tracking-widest uppercase">Atendimento na Grande BH</span>
      <h2 class="text-3xl sm:text-5xl font-extrabold tracking-tight text-brand-dark leading-tight">
        Chame Agora mesmo no WhatsApp e solicite um orçamento sem compromisso!
      </h2>
      <p class="text-lg text-brand-gray max-w-2xl mx-auto leading-relaxed">
        Não conviva com vazamentos. Nossa equipe faz consertos e reformas estruturais duráveis de maneira rápida e segura.
      </p>
      <div class="pt-4 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={companyInfo.whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 h-14 text-sm font-bold text-white bg-whatsapp hover:bg-whatsapp-hover rounded-xl shadow-xl transition-all"
        >
          Falar com Especialista pelo WhatsApp
        </a>
        <a
          href="/contato/"
          class="w-full sm:w-auto inline-flex items-center justify-center px-8 h-14 text-sm font-bold text-brand-dark bg-brand-bg-light hover:bg-brand-border rounded-xl transition-all"
        >
          Enviar Mensagem
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
