---
import BaseLayout from "@layouts/BaseLayout.astro";
import { companyInfo } from "@data/company";
import { getBreadcrumbSchema } from "@utils/schema";
import SectionTitle from "@components/ui/SectionTitle.astro";

const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Home", url: companyInfo.siteUrl },
  { name: "Contato", url: `${companyInfo.siteUrl}/contato/` }
]);
---

<BaseLayout
  title="Contato"
  description="Entre em contato com a Caixas São Bento para orçamentos de reforma, manutenção, limpeza e impermeabilização de caixas d'água em BH. Atendemos via WhatsApp."
  canonical={`${companyInfo.siteUrl}/contato/`}
  schema={breadcrumbSchema}
>
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-brand-dark to-[#100e16] text-white py-16 sm:py-24 overflow-hidden border-b border-primary/10">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#2351ff_1px,transparent_1px)] [background-size:16px_16px]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <nav class="flex items-center gap-2 text-xs text-brand-gray mb-4 font-medium" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-brand-gray/60"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
        <span class="text-brand-gray/80" aria-current="page">Contato</span>
      </nav>
      <div class="max-w-3xl">
        <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight text-white leading-tight mb-4">
          Fale Conosco
        </h1>
        <p class="text-lg text-brand-gray leading-relaxed">
          Saiba que podemos ajudar você. Entre em contato agora mesmo e solicite um orçamento sem compromisso!
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Grid -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- Contact Info Cards -->
        <div class="lg:col-span-2 space-y-6">
          <SectionTitle subtitle="Informações" title="Como nos encontrar" align="left" />

          <!-- WhatsApp -->
          <a href={companyInfo.whatsappUrl} target="_blank" rel="noopener noreferrer" class="group flex items-start gap-4 bg-brand-bg-light border border-brand-border/60 rounded-2xl p-5 hover:border-whatsapp/30 hover:shadow-md transition-all">
            <div class="w-12 h-12 rounded-xl bg-whatsapp/10 text-whatsapp flex items-center justify-center shrink-0 group-hover:bg-whatsapp group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="w-5 h-5 fill-current"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/></svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-brand-dark mb-1">WhatsApp</h3>
              <p class="text-sm text-brand-gray">{companyInfo.phone}</p>
              <span class="text-xs text-whatsapp font-semibold mt-1 inline-block">Clique para conversar →</span>
            </div>
          </a>

          <!-- Telefone -->
          <a href={`tel:${companyInfo.phoneRaw}`} class="group flex items-start gap-4 bg-brand-bg-light border border-brand-border/60 rounded-2xl p-5 hover:border-primary/30 hover:shadow-md transition-all">
            <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center shrink-0 group-hover:bg-primary group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.622c0-1.077.876-1.948 1.948-1.948 1.948 0 3.791.761 5.213 2.183l1.157 1.157c.725.725.725 1.899 0 2.624L9.124 12.18c.287.69.691 1.326 1.196 1.879.553.553 1.19 1.004 1.879 1.196l1.583-1.446c.725-.725 1.899-.725 2.624 0l1.157 1.157c1.422 1.422 2.183 3.265 2.183 5.213 0 1.072-.871 1.948-1.948 1.948-6.177 0-11.458-5.281-11.458-11.458Z" /></svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-brand-dark mb-1">Telefone</h3>
              <p class="text-sm text-brand-gray">{companyInfo.phone}</p>
              <span class="text-xs text-primary font-semibold mt-1 inline-block">Ligar agora →</span>
            </div>
          </a>

          <!-- Email -->
          <a href={`mailto:${companyInfo.email}`} class="group flex items-start gap-4 bg-brand-bg-light border border-brand-border/60 rounded-2xl p-5 hover:border-primary/30 hover:shadow-md transition-all">
            <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center shrink-0 group-hover:bg-primary group-hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0l-7.5-4.615a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-brand-dark mb-1">E-mail</h3>
              <p class="text-sm text-brand-gray">{companyInfo.email}</p>
            </div>
          </a>

          <!-- Address -->
          <div class="flex items-start gap-4 bg-brand-bg-light border border-brand-border/60 rounded-2xl p-5">
            <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25a7.5 7.5 0 1 1 15 0Z" /></svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-brand-dark mb-1">Endereço</h3>
              <p class="text-sm text-brand-gray">{companyInfo.address.street}, {companyInfo.address.number} - {companyInfo.address.neighborhood}</p>
              <p class="text-sm text-brand-gray">{companyInfo.address.city} - {companyInfo.address.state}, CEP {companyInfo.address.zipCode}</p>
            </div>
          </div>

          <!-- Hours -->
          <div class="flex items-start gap-4 bg-brand-bg-light border border-brand-border/60 rounded-2xl p-5">
            <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-brand-dark mb-1">Horário de Atendimento</h3>
              <p class="text-sm text-brand-gray">{companyInfo.openingHoursText}</p>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <div class="bg-brand-bg-light border border-brand-border/60 rounded-3xl p-6 sm:p-10 shadow-sm">
            <div class="space-y-2 mb-8">
              <h2 class="text-2xl font-bold text-brand-dark">Envie uma Mensagem</h2>
              <p class="text-sm text-brand-gray">Preencha o formulário abaixo ou entre em contato diretamente pelo WhatsApp para um atendimento mais rápido.</p>
            </div>
            <iframe name="lead-email-frame" class="hidden" title="Envio de formulario"></iframe>
            <form
              class="space-y-5"
              id="contact-form"
              action={`https://formsubmit.co/${companyInfo.email}`}
              method="POST"
              target="lead-email-frame"
              data-whatsapp-phone={companyInfo.phoneRaw}
            >
              <input type="hidden" name="_subject" value="Novo orçamento pelo site Caixa d'Água" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="hidden" name="_template" value="table" />
              <input type="hidden" name="origem" value="Página de contato do site caixadaagua.com.br" />
              <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="nome" class="block text-xs font-bold text-brand-dark mb-1.5 uppercase tracking-wider">Seu Nome *</label>
                  <input type="text" id="nome" name="nome" required class="w-full px-4 h-12 text-sm border border-brand-border/80 rounded-xl bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none" placeholder="Digite seu nome" />
                </div>
                <div>
                  <label for="telefone" class="block text-xs font-bold text-brand-dark mb-1.5 uppercase tracking-wider">Telefone *</label>
                  <input type="tel" id="telefone" name="telefone" required class="w-full px-4 h-12 text-sm border border-brand-border/80 rounded-xl bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none" placeholder="(31) 9 0000-0000" />
                </div>
              </div>
              <div>
                <label for="email" class="block text-xs font-bold text-brand-dark mb-1.5 uppercase tracking-wider">E-mail</label>
                <input type="email" id="email" name="email" class="w-full px-4 h-12 text-sm border border-brand-border/80 rounded-xl bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none" placeholder="seu@email.com" />
              </div>
              <div>
                <label for="servico" class="block text-xs font-bold text-brand-dark mb-1.5 uppercase tracking-wider">Serviço Desejado</label>
                <select id="servico" name="servico" class="w-full px-4 h-12 text-sm border border-brand-border/80 rounded-xl bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none text-brand-dark/70">
                  <option value="">Selecione um serviço</option>
                  <option value="reforma">Reforma de Caixa d'Água</option>
                  <option value="limpeza">Limpeza de Caixa d'Água</option>
                  <option value="manutencao">Manutenção de Caixa d'Água</option>
                  <option value="impermeabilizacao">Impermeabilização</option>
                  <option value="concreto">Reforma de Caixa de Concreto</option>
                  <option value="outro">Outro</option>
                </select>
              </div>
              <div>
                <label for="mensagem" class="block text-xs font-bold text-brand-dark mb-1.5 uppercase tracking-wider">Mensagem *</label>
                <textarea id="mensagem" name="mensagem" rows="5" required class="w-full px-4 py-3 text-sm border border-brand-border/80 rounded-xl bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none resize-none" placeholder="Descreva o problema ou serviço desejado..."></textarea>
              </div>
              <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center px-8 h-12 text-sm font-bold text-white bg-whatsapp hover:bg-whatsapp-hover rounded-xl shadow-md transition-all cursor-pointer">
                  Enviar pelo WhatsApp
                </button>
                <p id="form-status" class="text-xs text-brand-gray leading-relaxed" aria-live="polite">
                  Uma cópia dos dados também será enviada para nosso email.
                </p>
              </div>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
    const contactForm = document.getElementById("contact-form") as HTMLFormElement | null;
    const formStatus = document.getElementById("form-status");

    contactForm?.addEventListener("submit", (event) => {
      event.preventDefault();

      if (!contactForm.checkValidity()) {
        contactForm.reportValidity();
        return;
      }

      const formData = new FormData(contactForm);
      const nome = String(formData.get("nome") || "").trim();
      const telefone = String(formData.get("telefone") || "").trim();
      const email = String(formData.get("email") || "").trim();
      const mensagem = String(formData.get("mensagem") || "").trim();
      const servicoSelect = contactForm.querySelector<HTMLSelectElement>("#servico");
      const servico = servicoSelect?.selectedOptions[0]?.textContent?.trim() || "Não informado";
      const whatsappPhone = contactForm.dataset.whatsappPhone || "";

      const whatsappMessage = [
        "Olá, vim pelo site Caixa D'Água.",
        "",
        `Nome: ${nome}`,
        `Telefone: ${telefone}`,
        `Email: ${email || "Não informado"}`,
        `Serviço: ${servico}`,
        `Mensagem: ${mensagem}`,
      ].join("\n");

      contactForm.submit();

      if (formStatus) {
        formStatus.textContent = "Dados enviados. Abrindo WhatsApp para concluir o atendimento...";
      }

      window.open(`https://wa.me/${whatsappPhone}?text=${encodeURIComponent(whatsappMessage)}`, "_blank", "noopener,noreferrer");
      contactForm.reset();
    });
  </script>
</BaseLayout>
