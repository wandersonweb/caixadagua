---
import BaseLayout from "@layouts/BaseLayout.astro";
import { servicesData } from "@data/services";
import { companyInfo } from "@data/company";
import { getBreadcrumbSchema } from "@utils/schema";
import ServiceCard from "@components/ui/ServiceCard.astro";
import SectionTitle from "@components/ui/SectionTitle.astro";

const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Home", url: companyInfo.siteUrl },
  { name: "Serviços", url: `${companyInfo.siteUrl}/servicos/` }
]);
---

<BaseLayout
  title="Serviços"
  description="Conheça todos os serviços da Caixas São Bento: reforma, manutenção, limpeza e impermeabilização de caixas d'água em Belo Horizonte e região."
  canonical={`${companyInfo.siteUrl}/servicos/`}
  schema={breadcrumbSchema}
>
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-brand-dark to-[#100e16] text-white py-16 sm:py-24 overflow-hidden border-b border-primary/10">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#2351ff_1px,transparent_1px)] [background-size:16px_16px]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <nav class="flex items-center gap-2 text-xs text-brand-gray mb-4 font-medium" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-brand-gray/60"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
        <span class="text-brand-gray/80" aria-current="page">Serviços</span>
      </nav>
      <div class="max-w-3xl">
        <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight text-white leading-tight mb-4">
          Nossos Serviços Especializados
        </h1>
        <p class="text-lg text-brand-gray leading-relaxed">
          Oferecemos soluções completas para reforma, manutenção, limpeza e impermeabilização de caixas d'água. Confira abaixo nossos serviços e solicite um orçamento sem compromisso.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {servicesData.map((service) => (
          <ServiceCard service={service} />
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 sm:py-20 bg-brand-bg-light border-y border-brand-border/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <SectionTitle subtitle="Diferenciais da empresa" title="Por Que Nos Escolher?" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-12">
        <div class="bg-white border border-brand-border/60 rounded-2xl p-6 text-center shadow-sm hover:shadow-md transition-all">
          <div class="w-12 h-12 mx-auto rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.746 3.746 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" /></svg>
          </div>
          <h3 class="text-sm font-bold text-brand-dark mb-2">Equipe Qualificada</h3>
          <p class="text-xs text-brand-gray leading-relaxed">Profissionais com certificações NR33 e NR35 para segurança total.</p>
        </div>
        <div class="bg-white border border-brand-border/60 rounded-2xl p-6 text-center shadow-sm hover:shadow-md transition-all">
          <div class="w-12 h-12 mx-auto rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A1.75 1.75 0 1 0 19.75 18.5l-5.83-5.83M11.42 15.17a3 3 0 1 1-4.24-4.24 3 3 0 0 1 4.24 4.24Z" /></svg>
          </div>
          <h3 class="text-sm font-bold text-brand-dark mb-2">Soluções Personalizadas</h3>
          <p class="text-xs text-brand-gray leading-relaxed">Cada reservatório exige cuidados específicos. Adaptamos nosso trabalho.</p>
        </div>
        <div class="bg-white border border-brand-border/60 rounded-2xl p-6 text-center shadow-sm hover:shadow-md transition-all">
          <div class="w-12 h-12 mx-auto rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
          </div>
          <h3 class="text-sm font-bold text-brand-dark mb-2">Atendimento Rápido</h3>
          <p class="text-xs text-brand-gray leading-relaxed">Orçamento pelo WhatsApp em minutos, atendimento ágil em BH.</p>
        </div>
        <div class="bg-white border border-brand-border/60 rounded-2xl p-6 text-center shadow-sm hover:shadow-md transition-all">
          <div class="w-12 h-12 mx-auto rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
          </div>
          <h3 class="text-sm font-bold text-brand-dark mb-2">Garantia de Serviço</h3>
          <p class="text-xs text-brand-gray leading-relaxed">Todos os serviços com garantia formal de qualidade e vedação.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-20 bg-white text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6">
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-brand-dark">Precisa de um orçamento?</h2>
      <p class="text-lg text-brand-gray">Chame agora no WhatsApp e solicite um orçamento sem compromisso!</p>
      <a href={companyInfo.whatsappUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-8 h-14 text-sm font-bold text-white bg-whatsapp hover:bg-whatsapp-hover rounded-xl shadow-xl transition-all">
        Solicitar Orçamento Sem Compromisso
      </a>
    </div>
  </section>
</BaseLayout>
