---
interface Props {
  className?: string;
  hoverEffect?: boolean;
}

const { className = "", hoverEffect = true } = Astro.props;
---

<div class={`bg-white border border-brand-border/70 rounded-lg p-6 sm:p-8 shadow-sm transition-all duration-300 ${hoverEffect ? 'hover:surface-shadow hover:border-primary/20 hover:-translate-y-1' : ''} ${className}`}>
  <slot />
</div>
