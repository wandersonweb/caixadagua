---
import { footerNav } from "@data/navigation";
import { companyInfo } from "@data/company";

const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-dark text-white pt-16 pb-8 border-t border-brand-border/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <!-- Column 1: Brand Info -->
      <div class="space-y-4">
        <a href="/" class="flex items-center gap-2 group">
          <div class="w-10 h-10 rounded-xl bg-primary flex items-center justify-center text-white font-bold shadow-md shadow-primary/20">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.083.298.125.607.125.921 0 3.729-3.955 6.75-8.83 6.75-4.876 0-8.83-3.021-8.83-6.75 0-.314.041-.623.125-.921m17.41 0c-.297-1.077-1.373-1.921-2.775-2.274M20.25 8.511C19.066 7.424 17.3 6.75 15.35 6.75c-.868 0-1.69.135-2.433.376M3.415 8.511c.297-1.077 1.373-1.921 2.775-2.274m-2.775 2.274c1.184-1.087 2.95-1.761 4.9-1.761.868 0 1.69.135 2.433.376M12 18.75v-3.75m0 3.75a8.96 8.96 0 0 0 3-1.84M12 18.75a8.96 8.96 0 0 1-3-1.84M12 7.126a3.75 3.75 0 1 0 0-7.5 3.75 3.75 0 0 0 0 7.5Z" />
            </svg>
          </div>
          <div class="flex flex-col">
            <span class="text-lg font-extrabold tracking-tight text-white leading-none">CAIXAS SÃO BENTO</span>
            <span class="text-[10px] text-brand-gray tracking-widest font-semibold uppercase">Reforma & Manutenção</span>
          </div>
        </a>
        <p class="text-sm text-brand-gray leading-relaxed max-w-sm">
          {companyInfo.description} Referência em atendimento de qualidade, segurança e conformidade técnica na Grande BH.
        </p>
        <div class="flex items-center gap-3 pt-2">
          <span class="text-xs font-semibold text-brand-gray uppercase tracking-wider">Siga-nos:</span>
          <a href={companyInfo.facebook} target="_blank" rel="noopener noreferrer" class="text-brand-gray hover:text-white transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/></svg>
          </a>
          <a href={companyInfo.instagram} target="_blank" rel="noopener noreferrer" class="text-brand-gray hover:text-white transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div class="space-y-4 md:pl-8">
        <h3 class="text-sm font-bold tracking-wider text-white uppercase">Links Úteis</h3>
        <ul class="space-y-2.5">
          {footerNav.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-brand-gray hover:text-white transition-colors flex items-center gap-1.5 group">
                <span class="w-1.5 h-1.5 rounded-full bg-primary/40 group-hover:bg-primary transition-colors"></span>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Contact & Areas Served -->
      <div class="space-y-4">
        <h3 class="text-sm font-bold tracking-wider text-white uppercase">Contato & Atendimento</h3>
        <ul class="space-y-3 text-sm text-brand-gray">
          <li class="flex items-start gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-primary shrink-0 mt-0.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            <span>
              {companyInfo.address.street}, {companyInfo.address.number} - {companyInfo.address.neighborhood}<br />
              {companyInfo.address.city} - {companyInfo.address.state}, CEP {companyInfo.address.zipCode}
            </span>
          </li>
          <li class="flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-primary shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.622c0-1.077.876-1.948 1.948-1.948 1.948 0 3.791.761 5.213 2.183l1.157 1.157c.725.725.725 1.899 0 2.624L9.124 12.18c.287.69.691 1.326 1.196 1.879.553.553 1.19 1.004 1.879 1.196l1.583-1.446c.725-.725 1.899-.725 2.624 0l1.157 1.157c1.422 1.422 2.183 3.265 2.183 5.213 0 1.072-.871 1.948-1.948 1.948-6.177 0-11.458-5.281-11.458-11.458Z" />
            </svg>
            <a href={`tel:${companyInfo.phoneRaw}`} class="hover:text-white transition-colors">{companyInfo.phone}</a>
          </li>
          <li class="flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-primary shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0l-7.5-4.615a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            <a href={`mailto:${companyInfo.email}`} class="hover:text-white transition-colors">{companyInfo.email}</a>
          </li>
          <li class="flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-primary shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            <span>{companyInfo.openingHoursText}</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-brand-border/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-brand-gray">
      <p>
        &copy; {currentYear} {companyInfo.name}. Todos os direitos reservados.
      </p>
      <div class="flex items-center gap-4">
        <span>Regiões de Atendimento: BH, Nova Lima, Contagem, Betim e Região Metropolitana.</span>
      </div>
    </div>
  </div>
</footer>
