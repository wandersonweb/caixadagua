---
import { headerNav } from "@data/navigation";
import { companyInfo } from "@data/company";

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 w-full glassmorphism border-b border-brand-border/40 shadow-sm" id="main-header">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
    <!-- Brand / Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-primary to-primary-hover flex items-center justify-center text-white font-bold shadow-md shadow-primary/20 transform transition-transform group-hover:scale-105">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.083.298.125.607.125.921 0 3.729-3.955 6.75-8.83 6.75-4.876 0-8.83-3.021-8.83-6.75 0-.314.041-.623.125-.921m17.41 0c-.297-1.077-1.373-1.921-2.775-2.274M20.25 8.511C19.066 7.424 17.3 6.75 15.35 6.75c-.868 0-1.69.135-2.433.376M3.415 8.511c.297-1.077 1.373-1.921 2.775-2.274m-2.775 2.274c1.184-1.087 2.95-1.761 4.9-1.761.868 0 1.69.135 2.433.376M12 18.75v-3.75m0 3.75a8.96 8.96 0 0 0 3-1.84M12 18.75a8.96 8.96 0 0 1-3-1.84M12 7.126a3.75 3.75 0 1 0 0-7.5 3.75 3.75 0 0 0 0 7.5Z" />
        </svg>
      </div>
      <div class="flex flex-col">
        <span class="text-lg font-extrabold tracking-tight text-brand-dark leading-none group-hover:text-primary transition-colors">CAIXAS SÃO BENTO</span>
        <span class="text-[10px] text-brand-gray tracking-widest font-semibold uppercase">Reforma & Manutenção</span>
      </div>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-8">
      {headerNav.map((item) => (
        <div class="relative group/nav-item">
          {item.children ? (
            <button class="flex items-center gap-1 py-2 text-sm font-semibold text-brand-dark/80 hover:text-primary transition-colors cursor-pointer">
              {item.label}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 opacity-60 group-hover/nav-item:rotate-180 transition-transform duration-200">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div class="absolute left-1/2 -translate-x-1/2 top-full w-56 pt-2 opacity-0 pointer-events-none group-hover/nav-item:opacity-100 group-hover/nav-item:pointer-events-auto transition-all duration-200">
              <div class="bg-white rounded-xl shadow-lg border border-brand-border/60 py-2 overflow-hidden flex flex-col">
                {item.children.map((sub) => {
                  const isActive = currentPath === sub.href;
                  return (
                    <a
                      href={sub.href}
                      class={`px-4 py-2.5 text-xs font-medium transition-colors hover:bg-brand-bg-light ${isActive ? 'text-primary font-bold bg-primary-50/50' : 'text-brand-dark/75 hover:text-primary'}`}
                    >
                      {sub.label}
                    </a>
                  );
                })}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class={`text-sm font-semibold transition-colors ${currentPath === item.href ? "text-primary font-bold" : "text-brand-dark/80 hover:text-primary"}`}
            >
              {item.label}
            </a>
          )}
        </div>
      ))}
    </nav>

    <!-- Header Actions (Desktop) -->
    <div class="hidden md:flex items-center gap-4">
      <a href={`tel:${companyInfo.phoneRaw}`} class="text-xs font-semibold text-brand-dark/75 hover:text-primary flex items-center gap-1.5 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-primary">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.622c0-1.077.876-1.948 1.948-1.948 1.948 0 3.791.761 5.213 2.183l1.157 1.157c.725.725.725 1.899 0 2.624L9.124 12.18c.287.69.691 1.326 1.196 1.879.553.553 1.19 1.004 1.879 1.196l1.583-1.446c.725-.725 1.899-.725 2.624 0l1.157 1.157c1.422 1.422 2.183 3.265 2.183 5.213 0 1.072-.871 1.948-1.948 1.948-6.177 0-11.458-5.281-11.458-11.458Z" />
        </svg>
        {companyInfo.phone}
      </a>
      <a
        href={companyInfo.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 px-4 h-10 text-xs font-bold text-white bg-whatsapp hover:bg-whatsapp-hover rounded-xl shadow-md shadow-whatsapp/15 transform hover:-translate-y-0.5 active:translate-y-0 transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="w-4 h-4 fill-current">
          <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
        </svg>
        Orçamento Grátis
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button class="md:hidden p-2 rounded-lg text-brand-dark/80 hover:bg-brand-bg-light hover:text-primary transition-all cursor-pointer" id="menu-btn" aria-label="Abrir Menu">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6" id="menu-icon-hamburger">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>

  <!-- Mobile Drawer Menu -->
  <div class="hidden md:hidden fixed inset-x-0 top-20 bg-white border-b border-brand-border shadow-md max-h-[calc(100vh-5rem)] overflow-y-auto" id="mobile-drawer">
    <div class="px-4 py-6 space-y-4">
      {headerNav.map((item) => (
        <div class="flex flex-col">
          {item.children ? (
            <div class="space-y-2">
              <span class="text-xs font-semibold text-brand-gray uppercase tracking-widest">{item.label}</span>
              <div class="grid grid-cols-2 gap-2 pl-2">
                {item.children.map((sub) => {
                  const isActive = currentPath === sub.href;
                  return (
                    <a
                      href={sub.href}
                      class={`text-sm py-2 font-medium transition-colors ${isActive ? 'text-primary font-bold' : 'text-brand-dark hover:text-primary'}`}
                    >
                      {sub.label}
                    </a>
                  );
                })}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class={`text-base font-semibold py-2 transition-colors ${currentPath === item.href ? "text-primary" : "text-brand-dark hover:text-primary"}`}
            >
              {item.label}
            </a>
          )}
        </div>
      ))}
      <hr class="border-brand-border/60" />
      <div class="flex flex-col gap-4 py-2">
        <a href={`tel:${companyInfo.phoneRaw}`} class="flex items-center gap-2 text-sm font-semibold text-brand-dark hover:text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-primary">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.622c0-1.077.876-1.948 1.948-1.948 1.948 0 3.791.761 5.213 2.183l1.157 1.157c.725.725.725 1.899 0 2.624L9.124 12.18c.287.69.691 1.326 1.196 1.879.553.553 1.19 1.004 1.879 1.196l1.583-1.446c.725-.725 1.899-.725 2.624 0l1.157 1.157c1.422 1.422 2.183 3.265 2.183 5.213 0 1.072-.871 1.948-1.948 1.948-6.177 0-11.458-5.281-11.458-11.458Z" />
          </svg>
          {companyInfo.phone}
        </a>
        <a
          href={companyInfo.whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 w-full py-3 text-sm font-bold text-white bg-whatsapp hover:bg-whatsapp-hover rounded-xl shadow-md"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="w-4 h-4 fill-current">
            <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
          </svg>
          Falar no WhatsApp
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileDrawer = document.getElementById('mobile-drawer');

  if (menuBtn && mobileDrawer) {
    menuBtn.addEventListener('click', () => {
      mobileDrawer.classList.toggle('hidden');
    });

    // Close when clicking links
    const mobileLinks = mobileDrawer.querySelectorAll('a');
    mobileLinks.forEach((link) => {
      link.addEventListener('click', () => {
        mobileDrawer.classList.add('hidden');
      });
    });
  }

  // Header scroll appearance change
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (header) {
      if (window.scrollY > 20) {
        header.classList.remove('py-2');
        header.classList.add('shadow-md');
      } else {
        header.classList.add('py-2');
        header.classList.remove('shadow-md');
      }
    }
  });
</script>
