---
import BaseLayout from "@layouts/BaseLayout.astro";
import type { ServiceItem } from "@data/services";
import { getServiceSchema, getBreadcrumbSchema, getFAQSchema } from "@utils/schema";
import { companyInfo } from "@data/company";

interface Props {
  service: ServiceItem;
}

const { service } = Astro.props;

// Generate structured data
const pageUrl = `${companyInfo.siteUrl}/${service.slug}/`;
const serviceSchema = getServiceSchema(service.title, service.metaDescription, pageUrl);
const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Home", url: companyInfo.siteUrl },
  { name: "Serviços", url: `${companyInfo.siteUrl}/servicos/` },
  { name: service.title, url: pageUrl }
]);
const faqSchema = service.faqs.length > 0 ? getFAQSchema(service.faqs) : null;

const combinedSchemas: Record<string, any>[] = [serviceSchema, breadcrumbSchema];
if (faqSchema) {
  combinedSchemas.push(faqSchema);
}
---

<BaseLayout
  title={service.title}
  description={service.metaDescription}
  canonical={pageUrl}
  schema={combinedSchemas}
>
  <!-- Hero Section -->
  <section class="relative bg-brand-dark text-white py-16 sm:py-24 overflow-hidden border-b border-primary/10">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#2351ff_1px,transparent_1px)] [background-size:16px_16px]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <!-- Breadcrumbs -->
      <nav class="flex items-center gap-2 text-xs text-brand-gray mb-4 font-medium" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-brand-gray/60">
          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
        <a href="/servicos/" class="hover:text-white transition-colors">Serviços</a>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-brand-gray/60">
          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
        <span class="text-brand-gray/80 truncate max-w-[200px]" aria-current="page">{service.title}</span>
      </nav>

      <div class="max-w-3xl">
        <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight mb-4 text-white leading-tight">
          {service.headline}
        </h1>
        <p class="text-lg text-brand-gray mb-8 leading-relaxed">
          {service.shortDescription}
        </p>
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
          <a
            href={companyInfo.whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-6 h-12 text-sm font-bold text-white bg-whatsapp hover:bg-whatsapp-hover rounded-lg shadow-lg transition-all transform hover:-translate-y-0.5 focus-ring"
          >
            Orçamento pelo WhatsApp
          </a>
          <a
            href="/contato/"
            class="inline-flex items-center justify-center px-6 h-12 text-sm font-bold text-white bg-white/10 hover:bg-white/20 border border-white/10 hover:border-white/20 rounded-lg transition-all focus-ring"
          >
            Falar com Atendente
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Split Grid -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
        
        <!-- Left Side: Main Text content -->
        <div class="lg:col-span-2 space-y-8">
          <div class="space-y-6 text-brand-dark/85 leading-relaxed text-base [&_a]:font-semibold [&_a]:text-primary [&_a]:underline [&_a]:decoration-primary/30 [&_a]:underline-offset-4 hover:[&_a]:text-primary-hover hover:[&_a]:decoration-primary-hover/60 [&_h2]:pt-6 [&_h2]:text-2xl [&_h2]:sm:text-3xl [&_h2]:font-extrabold [&_h2]:tracking-tight [&_h2]:text-brand-dark [&_h2]:leading-tight [&_h3]:pt-4 [&_h3]:text-xl [&_h3]:sm:text-2xl [&_h3]:font-bold [&_h3]:tracking-tight [&_h3]:text-brand-dark [&_h3]:leading-tight [&_ul]:space-y-3 [&_ul]:pl-5 [&_li]:list-disc [&_li]:marker:text-primary [&_strong]:font-bold [&_strong]:text-brand-dark">
            <slot />
          </div>

          <!-- Step-by-Step Process -->
          {service.process && service.process.length > 0 && (
            <div class="pt-8 border-t border-brand-border/60">
              <h2 class="text-2xl font-bold tracking-tight text-brand-dark mb-6">Como funciona o nosso serviço?</h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                {service.process.map((step, index) => (
                  <div class="flex gap-4 p-5 rounded-lg bg-brand-bg-light border border-brand-border/40 relative">
                    <span class="absolute top-4 right-4 text-4xl font-black text-primary/10 select-none">0{index + 1}</span>
                    <div class="w-8 h-8 rounded-lg bg-primary/10 text-primary flex items-center justify-center font-bold text-sm shrink-0">
                      {index + 1}
                    </div>
                    <div class="space-y-1 relative z-10">
                      <span class="text-xs font-semibold text-brand-gray uppercase tracking-wider">Passo 0{index + 1}</span>
                      <p class="text-sm text-brand-dark/80 font-medium leading-relaxed">{step}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- FAQs (Accordion) -->
          {service.faqs && service.faqs.length > 0 && (
            <div class="pt-12 border-t border-brand-border/60">
              <h2 class="text-2xl font-bold tracking-tight text-brand-dark mb-6">Dúvidas Frequentes</h2>
              <div class="space-y-4">
                {service.faqs.map((faq) => (
                  <details class="group bg-brand-bg-light border border-brand-border/50 rounded-lg p-5 [&_summary::-webkit-details-marker]:hidden cursor-pointer transition-all hover:border-brand-border">
                    <summary class="flex items-center justify-between gap-4 font-bold text-brand-dark text-base list-none">
                      <span>{faq.question}</span>
                      <span class="w-6 h-6 rounded-lg bg-white flex items-center justify-center shadow-sm text-brand-dark group-open:rotate-180 transition-transform duration-200">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 opacity-60">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                        </svg>
                      </span>
                    </summary>
                    <p class="mt-4 text-sm text-brand-gray leading-relaxed pl-1">
                      {faq.answer}
                    </p>
                  </details>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Right Side: Sidebar Cards -->
        <div class="space-y-8 lg:sticky lg:top-24">
          <!-- Benefits Card -->
          <div class="bg-gradient-to-b from-brand-bg-light to-white border border-brand-border/60 rounded-lg p-6 sm:p-8 shadow-sm">
            <h3 class="text-lg font-bold text-brand-dark mb-6 flex items-center gap-2">
              <span class="w-1.5 h-6 rounded-full bg-primary"></span>
              Vantagens de Escolher a Caixas São Bento
            </h3>
            <ul class="space-y-4">
              {service.benefits.map((benefit) => (
                <li class="flex items-start gap-3">
                  <span class="w-5 h-5 rounded-full bg-primary/10 text-primary flex items-center justify-center shrink-0 mt-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-3 h-3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                  </span>
                  <span class="text-sm text-brand-dark/80 leading-relaxed font-medium">{benefit}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Contact Form / Sidebar CTA Card -->
          <div class="bg-brand-dark text-white rounded-lg p-6 sm:p-8 shadow-lg relative overflow-hidden">
            <div class="absolute inset-0 opacity-5 bg-[radial-gradient(#2351ff_1px,transparent_1px)] [background-size:12px_12px]"></div>
            <div class="relative z-10 space-y-6">
              <div class="space-y-2">
                <span class="text-[10px] text-brand-gray tracking-widest font-semibold uppercase">Orçamento sem compromisso</span>
                <h3 class="text-xl font-bold tracking-tight text-white leading-tight">Pronto para resolver seus problemas com a caixa d'água?</h3>
              </div>
              <p class="text-xs text-brand-gray leading-relaxed">
                Nossos consultores técnicos atendem residências, indústrias, comércio e condomínios na Grande BH com agilidade.
              </p>
              <div class="space-y-3 pt-2">
                <a
                  href={companyInfo.whatsappUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center justify-center gap-2 w-full py-3.5 text-sm font-bold text-white bg-whatsapp hover:bg-whatsapp-hover rounded-lg shadow-md transition-all transform hover:-translate-y-0.5 focus-ring"
                >
                  Falar pelo WhatsApp
                </a>
                <a
                  href="/contato/"
                  class="flex items-center justify-center w-full py-3.5 text-sm font-bold text-white bg-white/10 hover:bg-white/20 border border-white/10 rounded-lg transition-all focus-ring"
                >
                  Formulário de Contato
                </a>
              </div>
              <div class="text-center pt-2">
                <span class="text-[10px] text-brand-gray tracking-wider">Atendimento das 9h às 17h, todos os dias.</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
