---
import BaseLayout from "@layouts/BaseLayout.astro";
import { companyInfo } from "@data/company";
import { getBreadcrumbSchema } from "@utils/schema";

interface Props {
  title: string;
  description: string;
  pubDate?: string;
  category?: string;
  ogImage?: string;
  slug: string;
}

const { title, description, pubDate = "21 de Agosto de 2024", category = "Manutenção", ogImage, slug } = Astro.props;

const pageUrl = `${companyInfo.siteUrl}/${slug}/`;
const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Home", url: companyInfo.siteUrl },
  { name: "Conteúdos", url: companyInfo.siteUrl },
  { name: title, url: pageUrl }
]);
---

<BaseLayout
  title={title}
  description={description}
  canonical={pageUrl}
  ogImage={ogImage}
  schema={breadcrumbSchema}
>
  <article class="bg-white py-12 sm:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs -->
      <nav class="flex items-center gap-2 text-xs text-brand-gray mb-6 font-medium" aria-label="Breadcrumb">
        <a href="/" class="hover:text-brand-dark transition-colors">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-brand-gray/60">
          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
        <a href="/servicos/" class="hover:text-brand-dark transition-colors">Serviços</a>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-brand-gray/60">
          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
        <span class="text-brand-gray/80 truncate max-w-[200px]" aria-current="page">{title}</span>
      </nav>

      <!-- Post Header -->
      <div class="space-y-4 mb-10 text-center md:text-left">
        <div class="flex flex-wrap items-center gap-3 justify-center md:justify-start">
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-primary/10 text-primary uppercase tracking-wide">
            {category}
          </span>
          <span class="text-xs text-brand-gray font-semibold uppercase tracking-wider">
            {pubDate}
          </span>
        </div>
        <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight text-brand-dark leading-tight">
          {title}
        </h1>
        <p class="text-lg text-brand-gray leading-relaxed max-w-3xl">
          {description}
        </p>
      </div>

      <!-- Divider -->
      <hr class="border-brand-border/60 mb-10" />

      <!-- Post Body Content -->
      <div class="prose prose-slate max-w-none text-brand-dark/85 leading-relaxed text-base space-y-6">
        <slot />
      </div>

      <!-- Post Footer CTA -->
      <div class="mt-16 bg-gradient-to-br from-brand-dark to-[#100e16] text-white rounded-3xl p-8 sm:p-12 shadow-xl relative overflow-hidden text-center sm:text-left">
        <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#2351ff_1px,transparent_1px)] [background-size:16px_16px]"></div>
        <div class="relative z-10 grid grid-cols-1 md:grid-cols-5 gap-8 items-center">
          <div class="md:col-span-3 space-y-3">
            <span class="text-xs font-bold text-primary tracking-widest uppercase">Precisa de um Profissional?</span>
            <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-white leading-tight">Ficou com alguma dúvida ou precisa de reparos?</h2>
            <p class="text-sm text-brand-gray leading-relaxed">
              Realizamos vistorias técnicas completas e executamos consertos com resina e fibra de vidro em BH e região.
            </p>
          </div>
          <div class="md:col-span-2 flex flex-col sm:flex-row md:flex-col gap-3 justify-center">
            <a
              href={companyInfo.whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 px-6 h-12 text-sm font-bold text-white bg-whatsapp hover:bg-whatsapp-hover rounded-xl shadow-lg transition-all transform hover:-translate-y-0.5 active:translate-y-0"
            >
              Falar no WhatsApp
            </a>
            <a
              href="/contato/"
              class="inline-flex items-center justify-center px-6 h-12 text-sm font-bold text-white bg-white/10 hover:bg-white/20 border border-white/10 rounded-xl transition-all"
            >
              Fale Conosco
            </a>
          </div>
        </div>
      </div>

    </div>
  </article>
</BaseLayout>
