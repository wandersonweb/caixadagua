---
import "@styles/global.css";
import SEOHead from "@components/seo/SEOHead.astro";
import Navbar from "@components/layout/Navbar.astro";
import Footer from "@components/layout/Footer.astro";
import WhatsAppButton from "@components/ui/WhatsAppButton.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  isHome?: boolean;
  schema?: Record<string, any> | Record<string, any>[];
}

const { title, description, canonical, ogImage, isHome = false, schema } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QKZ4JE8305"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-QKZ4JE8305');
    </script>
    <meta name="google-site-verification" content="6GYrtU2FSwHyZiO_DnNv2cbvHc_Me4hqEY3eNw-4fJ0" />

    <!-- Meta Pixel Code: cole aqui o pixel do Facebook/Meta quando precisar. -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      isHome={isHome}
      schema={schema}
    />
  </head>
  <body class="bg-white text-brand-dark flex flex-col min-h-screen font-sans">
    <Navbar />
    <main class="flex-grow pt-20">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
  </body>
</html>
